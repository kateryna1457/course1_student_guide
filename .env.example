# PostgreSQL Container Configuration
POSTGRES_USER=student_user
POSTGRES_PASSWORD=student_pass
POSTGRES_DB=students_db

# Application Database Configuration (for Docker)
DB_HOST=postgres
DB_PORT=5432
DB_USER=student_user
DB_PASSWORD=student_pass
DB_NAME=students_db
DATABASE_SCHEMA=s_university

# Application Configuration
APP_NAME=Student Directory API
APP_VERSION=1.0.0
DEBUG=True

# API Configuration
API_PREFIX=/api
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
